# Environment
.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/

# Jupyter
.ipynb_checkpoints/

# Model weights (large files — push adapter to HuggingFace instead)
*.bin
*.safetensors
*.pt
*.pth
training/checkpoints/
training/output/

# Held-out partition — never commit unencrypted to public repo
tenacious_bench_v0.1/held_out/*.jsonl
tenacious_bench_v0.1/held_out/*.json
!tenacious_bench_v0.1/held_out/.gitkeep

# Intermediate pipeline artifacts (not final dataset)
tenacious_bench_v0.1/deduped/
tenacious_bench_v0.1/train_filtered/

# Training data (formatted pairs for fine-tuning — push to HuggingFace separately)
training_data/

# Test output sinks
email_sink.jsonl

# API keys / secrets
*.key
secrets/

# OS
.DS_Store
Thumbs.db

# Logs (keep structured logs, ignore raw)
*.log
!training/*.log
