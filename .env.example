# Copy this file to .env and fill in your values. NEVER commit .env to git.

# OpenRouter API key (for multi-LLM synthesis and judge calls)
OPENROUTER_API_KEY=sk-or-...

# Anthropic API key (for eval-tier judge — Claude Sonnet 4.6)
ANTHROPIC_API_KEY=sk-ant-...

# HuggingFace Hub token (write access for dataset + model upload)
HF_TOKEN=hf_...

# HuggingFace username/org
HF_USERNAME=your-hf-handle

# Langfuse observability (reused from Week 10)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Reproducibility seed (keep fixed throughout the project)
RANDOM_SEED=42
